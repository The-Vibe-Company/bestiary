generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: User authentication is managed by Neon Auth (in neon_auth schema)
// This User model syncs with Neon Auth to add custom fields and constraints

model User {
  id        String   @id // Same ID as Neon Auth
  email     String   @unique
  username  String   @unique // Pseudo - must be unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  village   Village?
  resources UserResources?

  @@map("Users")
}

model Village {
  id          String              @id @default(cuid())
  name        String?             @unique // Nom unique du village (optionnel initialement)
  x           Int
  y           Int
  capacity    Int                 @default(4) // Max population (upgradeable)
  ownerId     String              @unique // 1 village par user
  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  inhabitants VillageInhabitants?
  resources   VillageResources?
  missions    Mission[]
  buildings      VillageBuilding[]
  technologies   VillageTechnology[]
  traveler       VillageTraveler?
  notifications  Notification[]
  items          VillageItem[]

  @@unique([x, y]) // Une seule village par coordonnée
  @@map("Villages")
}

model UserResources {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  or        Int      @default(10)
  savoir    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("UserResources")
}

model VillageResources {
  id        String   @id @default(cuid())
  villageId String   @unique
  village   Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)
  bois      Int      @default(100)
  pierre    Int      @default(50)
  cereales  Float    @default(30)
  viande    Float    @default(20)
  lastConsumptionAt  DateTime  @default(now())
  lastStarvationAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("VillageResources")
}

model VillageInhabitants {
  id         String   @id @default(cuid())
  villageId  String   @unique
  village    Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)
  lumberjack Int      @default(0) // Bûcheron
  miner      Int      @default(0) // Mineur
  explorer   Int      @default(0) // Explorateur
  hunter     Int      @default(0) // Chasseur
  gatherer   Int      @default(0) // Cueilleur
  breeder    Int      @default(0) // Éleveur
  farmer     Int      @default(0) // Agriculteur
  researcher   Int      @default(0) // Chercheur
  builder      Int      @default(0) // Bâtisseur
  watchman     Int      @default(0) // Guetteur
  tavernkeeper Int      @default(0) // Tavernier
  mayor        Int      @default(0) // Maire
  splitter     Int      @default(0) // Fendeur
  stonecutter  Int      @default(0) // Tailleur de pierre
  victualer    Int      @default(0) // Vivandier
  butcher      Int      @default(0) // Boucher
  createdAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("VillageInhabitants")
}

model InhabitantType {
  id          String @id @default(cuid())
  key         String @unique // lumberjack, miner, etc.
  title       String // Bûcheron, Mineur, etc.
  description String
  image       String
  order       Int    // Display order
  speed           Float  @default(0)  // tiles per hour (0 = no missions)
  gatherRate      Float  @default(0)  // resources per hour of work
  maxCapacity     Int    @default(0)  // max carry capacity
  consumeCereales Float  @default(0)  // daily cereal consumption per unit
  consumeViande   Float  @default(0)  // daily meat consumption per unit

  @@map("InhabitantTypes")
}

model BuildingType {
  id            String @id @default(cuid())
  key           String @unique
  title         String
  description   String
  image         String
  order         Int
  category      String @default("centre") // centre, ressources, savoir, militaire, social
  costBois      Int    @default(0)
  costPierre    Int    @default(0)
  costCereales  Int    @default(0)
  costViande    Int    @default(0)
  buildSeconds  Int
  capacityBonus Int    @default(0)
  storageBonusBois     Int @default(0)
  storageBonusPierre   Int @default(0)
  storageBonusCereales Int @default(0)
  storageBonusViande   Int @default(0)
  maxCount           Int?    // null = unlimited, e.g. 1 for unique buildings like laboratory
  maxLevel           Int     @default(1) // max upgrade level for unique buildings
  requiredTechnology String? // Technology key that must be completed before building

  @@map("BuildingTypes")
}

model Technology {
  id              String @id @default(cuid())
  key             String @unique
  title           String
  description     String
  image           String
  order           Int
  costBois        Int    @default(0)
  costPierre      Int    @default(0)
  costCereales    Int    @default(0)
  costViande      Int    @default(0)
  researchSeconds Int
  requiredLabLevel Int   @default(1)
  maxLevel        Int    @default(1)

  @@map("Technologies")
}

model VillageTechnology {
  id                  String    @id @default(cuid())
  villageId           String
  village             Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  technologyKey       String
  level               Int       @default(1)
  startedAt           DateTime  @default(now())
  researchSeconds     Int
  assignedResearchers Int       @default(1)
  completedAt         DateTime?
  createdAt           DateTime  @default(now())

  @@unique([villageId, technologyKey])
  @@map("VillageTechnologies")
}

model VillageBuilding {
  id               String    @id @default(cuid())
  villageId        String
  village          Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  buildingType     String
  level            Int       @default(1) // building level (for upgradeable unique buildings)
  startedAt        DateTime  @default(now())
  buildSeconds     Int
  assignedBuilders Int       @default(1)
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@map("VillageBuildings")
}

model VillageTraveler {
  id         String    @id @default(cuid())
  villageId  String    @unique // Un seul voyageur actif par village
  village    Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  arrivesAt  DateTime  // Quand le voyageur devient visible
  departsAt  DateTime  // Quand il repart si non assigné
  welcomedAt DateTime? // Set quand le joueur accueille le voyageur
  assignedAt DateTime? // Set quand le joueur assigne le voyageur a un metier
  detectedAt DateTime? // Set quand la tour de guet détecte le voyageur (évite les notifications en double)
  createdAt  DateTime  @default(now())

  @@map("VillageTravelers")
}

model Notification {
  id        String    @id @default(cuid())
  villageId String
  village   Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  type      String    // "starvation", "mission_complete", etc.
  title     String
  message   String
  data      Json?     // Type-specific metadata (deaths count, resource info, etc.)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([villageId, readAt])
  @@map("Notifications")
}

model Mission {
  id             String    @id @default(cuid())
  villageId      String
  village        Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  inhabitantType String    // "lumberjack", "explorer", etc.
  workerCount    Int       @default(1) // number of workers assigned to this mission
  targetX        Int
  targetY        Int
  departedAt     DateTime  @default(now())
  travelSeconds  Int       // one-way travel duration (pre-computed)
  workSeconds    Int       // work duration (chosen by player)
  loop           Boolean   @default(false)
  recalledAt     DateTime? // set if recalled during outbound travel
  completedAt    DateTime? // set when resources have been collected
  createdAt      DateTime  @default(now())
  discoveredItems VillageItem[]

  @@map("Missions")
}

model VillageItem {
  id           String   @id @default(cuid())
  villageId    String
  village      Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)
  missionId    String?
  mission      Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  rarity       String   // "commun", "rare", "epique", "legendaire", "mythique"
  discoveredAt DateTime @default(now())

  @@index([villageId])
  @@map("VillageItems")
}
